# ============================================================================
# @lsp-indexer Test App — Environment Variables
# ============================================================================
#
# Copy this file to .env and fill in your Hasura GraphQL endpoint(s).
# You need at least ONE of NEXT_PUBLIC_INDEXER_URL or INDEXER_URL to use the app.
#
# Client mode (@lsp-indexer/react): Browser connects to Hasura directly
# Server mode (@lsp-indexer/next): Browser → Next.js Server Action → Hasura
#
# ============================================================================

# --- Client-side (exposed to browser) ---

# HTTP endpoint for @lsp-indexer/react hooks (browser → Hasura directly)
NEXT_PUBLIC_INDEXER_URL=https://your-hasura-instance.com/v1/graphql

# WebSocket endpoint for subscriptions (browser connects here)
# Point at the WS proxy to keep the upstream Hasura URL hidden.
# Falls back to NEXT_PUBLIC_INDEXER_URL with wss:// protocol if not set.
# NEXT_PUBLIC_INDEXER_WS_URL=wss://your-ws-proxy.example.com/v1/graphql

# --- Server-side only (never exposed to browser) ---

# HTTP endpoint for @lsp-indexer/next server actions (server → Hasura)
INDEXER_URL=https://your-hasura-instance.com/v1/graphql

# Upstream WebSocket endpoint for the WS proxy (proxy → Hasura)
# Falls back to INDEXER_URL with wss:// protocol if not set
# INDEXER_WS_URL=wss://your-hasura-instance.com/v1/graphql

# Allowed origins for the WS proxy CORS validation (comma-separated)
# Required when running the WS proxy (dev and production)
# INDEXER_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.com

# Port for the WebSocket subscription proxy (default: 4000)
# WS_PROXY_PORT=4000
