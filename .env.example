# ==============================================================================
# PostgreSQL Database Configuration
# ==============================================================================

# Database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Optional: Custom volume path for PostgreSQL data (docker-compose only)
# Default: Docker named volume
POSTGRES_VOLUME_PATH=

# ==============================================================================
# Indexer Configuration
# ==============================================================================

# Database connection URL for the indexer
# This URL is used by Subsquid's TypeORM store to persist indexed data
DB_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# --- Blockchain Data Sources ---

# Subsquid Gateway (archive node) - provides historical blockchain data
# Default: https://v2.archive.subsquid.io/network/lukso-mainnet
SQD_GATEWAY=

# LUKSO RPC endpoint - used for real-time queries and supportsInterface checks
# Default: https://rpc.lukso.sigmacore.io
RPC_URL=

# RPC rate limit (requests per second) - prevents overwhelming the RPC endpoint
# Default: 10
RPC_RATE_LIMIT=

# Finality confirmation (blocks) - how many blocks to wait before considering data final
# Default: 75 (LUKSO recommended)
FINALITY_CONFIRMATION=

# --- IPFS & Metadata Fetching ---

# IPFS gateway for fetching metadata (LSP3, LSP4, LSP12 profiles)
# Default: https://api.universalprofile.cloud/ipfs/
IPFS_GATEWAY=

# Maximum number of metadata items to fetch in a single batch
# Default: 10000
FETCH_LIMIT=

# Batch size for parallel metadata fetching
# Default: 1000
FETCH_BATCH_SIZE=

# Number of retry attempts for failed metadata fetches
# Default: 5
FETCH_RETRY_COUNT=

# Worker pool size for parallel metadata fetching (number of worker threads)
# Default: 4
METADATA_WORKER_POOL_SIZE=

# --- Logging Configuration (Indexer V2) ---

# Log level for file and console output
# Options: debug, info, warn, error
# Default: debug (development), info (production based on NODE_ENV)
LOG_LEVEL=

# Directory for log files (both JSON and console logs)
# Default: ./logs
LOG_DIR=

# Enable/disable JSON file logging (pino with daily rotation)
# Set to 'false' to disable file logging (console output only)
# Default: true
# Note: `pnpm start:simple` automatically sets this to false
INDEXER_ENABLE_FILE_LOGGER=

# Node environment (affects default log level)
# Options: production, development
# Default: development
NODE_ENV=

# ==============================================================================
# Hasura GraphQL Engine (Optional)
# ==============================================================================
# Enable Hasura GraphQL API for querying indexed data
# Hasura provides a GraphQL interface over the PostgreSQL database

# Enable Hasura services (set to 'true' to start Hasura + data-connector)
# When enabled, Hasura will be available at http://localhost:8080
# Default: not set (Hasura disabled)
# ENABLE_HASURA=true

# Hasura admin secret (password for Hasura console)
# IMPORTANT: Change this to a strong secret in production!
# Default: admin_secret_change_me
HASURA_GRAPHQL_ADMIN_SECRET=

# Hasura console port (exposed on host)
# Default: 8080
HASURA_GRAPHQL_PORT=

# Enable Hasura web console UI
# Default: true
HASURA_GRAPHQL_ENABLE_CONSOLE=

# Enable development mode (detailed errors, etc.)
# Set to 'false' in production
# Default: true
HASURA_GRAPHQL_DEV_MODE=

# Log types to enable (comma-separated)
# Default: startup,http-log,webhook-log,websocket-log,query-log
HASURA_GRAPHQL_ENABLED_LOG_TYPES=

# Hasura data connector configuration (for advanced features)
# Default: configured for data-connector-agent service
HASURA_GRAPHQL_METADATA_DEFAULTS=

# Unauthorized role (allows public access to certain queries)
# Default: public
HASURA_GRAPHQL_UNAUTHORIZED_ROLE=

# Legacy v1 compatibility (not needed for v2)
PG_DATABASE_URL=${DB_URL}
HASURA_GRAPHQL_DATABASE_URL=${DB_URL}
HASURA_GRAPHQL_METADATA_DATABASE_URL=${DB_URL}
HASURA_GRAPHQL_ENDPOINT=http://hasura:8080
