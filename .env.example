# ==============================================================================
# Production Environment Configuration
# ==============================================================================
#
# Copy this file to ../.env.prod and set the REQUIRED variables before starting.
#
# Usage:
#   cp .env.prod.example ../.env.prod
#   nano ../.env.prod
#   docker compose -f docker-compose.prod.yml --env-file ../.env.prod up -d
#
# ==============================================================================

# ==============================================================================
# REQUIRED — Production compose will fail if these are unset
# ==============================================================================

# Strong password for PostgreSQL database
# Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=

# Strong secret for Hasura admin console access
# Generate one with: openssl rand -base64 32
HASURA_GRAPHQL_ADMIN_SECRET=

# LUKSO Mainnet RPC endpoint for real-time queries and supportsInterface checks
# Examples:
#   https://rpc.lukso.sigmacore.io (public, rate-limited)
#   https://rpc.mainnet.lukso.network (official)
#   https://your-private-rpc.example.com (private, recommended for production)
RPC_URL_LUKSO=

# ==============================================================================
# OPTIONAL — Have sane defaults in the compose file
# ==============================================================================

# --- Docker ---

# Project name prefix for all container names (e.g. lsp-indexer-postgres, lsp-indexer-grafana)
# Change this if running multiple instances on the same host to avoid name collisions
# Default: lsp-indexer
COMPOSE_PROJECT_NAME=lsp-indexer

# --- PostgreSQL ---

# Database user (default: postgres)
POSTGRES_USER=postgres

# Database name (default: postgres)
POSTGRES_DB=postgres

# --- Indexer ---

# Chain identifier for multi-chain support
# Used to partition data in shared PostgreSQL database
# Default: lukso (mainnet)
CHAIN_ID=

# Docker image version to pull from ghcr.io/chillwhales/lsp-indexer
# Pin to a specific version for reproducible deployments
# Examples: latest, v0.1.0, abc1234
INDEXER_VERSION=latest

# LUKSO Subsquid Gateway for historical blockchain data
# Default: https://v2.archive.subsquid.io/network/lukso-mainnet
SQD_GATEWAY_LUKSO=

# LUKSO RPC rate limit — requests per second to avoid overwhelming the RPC endpoint
# Default: 10
RPC_RATE_LIMIT_LUKSO=

# LUKSO finality confirmation — blocks to wait before considering data final
# Default: 75
FINALITY_CONFIRMATION_LUKSO=

# --- Ethereum Mainnet Indexer ---

# Ethereum Mainnet RPC endpoint
# Default: https://eth.drpc.org
RPC_URL_ETHEREUM=

# Ethereum Mainnet RPC rate limit — requests per second
# Default: 10
RPC_RATE_LIMIT_ETHEREUM=

# Ethereum Mainnet finality confirmation — blocks to wait
# Default: 12
FINALITY_CONFIRMATION_ETHEREUM=

# --- Ethereum Sepolia Indexer ---

# Ethereum Sepolia RPC endpoint
# Default: https://sepolia.drpc.org
RPC_URL_ETHEREUM_SEPOLIA=

# Ethereum Sepolia RPC rate limit — requests per second
# Default: 10
RPC_RATE_LIMIT_ETHEREUM_SEPOLIA=

# Ethereum Sepolia finality confirmation — blocks to wait
# Default: 12
FINALITY_CONFIRMATION_ETHEREUM_SEPOLIA=

# --- IPFS & Metadata ---

# IPFS gateway for fetching metadata (LSP3, LSP4, LSP12 profiles)
# Default: https://ipfs.io/ipfs/
IPFS_GATEWAY=

# Maximum number of metadata items to fetch in a single batch
# Default: 10000
FETCH_LIMIT=

# Batch size for parallel metadata fetching
# Default: 1000
FETCH_BATCH_SIZE=

# Number of retry attempts for failed metadata fetches
# Default: 5
FETCH_RETRY_COUNT=

# Worker pool size for parallel metadata fetching (number of worker threads)
# Default: 4
METADATA_WORKER_POOL_SIZE=

# --- Logging ---

# Log level: debug, info, warn, error
# Default: info
LOG_LEVEL=

# --- Hasura ---

# Hasura console port (exposed on host)
# Default: 8080
HASURA_GRAPHQL_PORT=

# Enable Hasura web console UI (default: false in production)
HASURA_GRAPHQL_ENABLE_CONSOLE=false

# Enable development mode with detailed errors (default: false in production)
HASURA_GRAPHQL_DEV_MODE=false

# Unauthorized role — allows public access to certain queries
# Default: public
HASURA_GRAPHQL_UNAUTHORIZED_ROLE=

# --- Monitoring ---

# Grafana dashboard port (exposed on host)
# Default: 3000
GRAFANA_PORT=

# Grafana admin credentials for editing dashboards (anonymous read-only always enabled)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
