    {
      "type": "timeseries",
      "title": "Metadata Fetch Performance",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "max by (entityKey) (max_over_time({compose_service=\"indexer\"} | json | entityKey != \"\" | durationMs > 0 | unwrap durationMs [$__interval]))",
          "legendFormat": "{{entityKey}} duration"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (entityKey) (max_over_time({compose_service=\"indexer\"} | json | unfetchedCount > 0 | unwrap unfetchedCount [$__interval]))",
          "legendFormat": "{{entityKey}} backlog"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (entityKey) (sum_over_time({compose_service=\"indexer\"} | json | totalProcessed > 0 | unwrap totalProcessed [$__interval]))",
          "legendFormat": "{{entityKey}} processed"
        },
        {
          "refId": "D",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (entityKey) (sum_over_time({compose_service=\"indexer\"} | json | totalFailed > 0 | unwrap totalFailed [$__interval]))",
          "legendFormat": "{{entityKey}} failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed.*" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*(backlog|processed|failed).*" },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "last"]
        }
