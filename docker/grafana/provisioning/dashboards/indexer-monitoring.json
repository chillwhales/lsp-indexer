{
  "uid": "lsp-indexer-monitoring",
  "title": "LSP Indexer Monitoring",
  "tags": ["indexer", "monitoring", "lsp"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(compose_service)",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(container_cpu_usage_seconds_total, container_label_com_docker_compose_project)",
        "multi": false,
        "includeAll": false,
        "current": { "selected": false, "text": "", "value": "" },
        "refresh": 2
      },
      {
        "name": "log_lines",
        "label": "Log Lines",
        "type": "custom",
        "query": "50,100,200,500,1000",
        "current": { "selected": true, "text": "200", "value": "200" },
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Current Block",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "max(max_over_time({compose_service=\"indexer\"} | json | unwrap blockNumber [1h]))",
        "queryType": "range"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 }
    },
    {
      "type": "stat",
      "title": "Blocks/min",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({compose_service=\"indexer\"} | json | blockNumber > 0 [5m])) / 5",
        "queryType": "range"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0 },
            { "color": "green", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 }
    },
    {
      "type": "stat",
      "title": "Block Processing Activity (1m)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({compose_service=\"indexer\"} | json | blockNumber > 0 [$__interval]))",
        "queryType": "range"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "noValue": "No data",
          "mappings": [{ "type": "special", "options": { "match": "null", "result": { "text": "Stale", "color": "red" } } }]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"
      },
      "description": "Block-processing log entries per interval. 0 or no data indicates the indexer may be stalled.",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 }
    },
    {
      "type": "stat",
      "title": "Errors (1h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({compose_service=~\"$service\"} | json | level=~\"error|fatal|ERROR|FATAL\" [1h]))",
        "queryType": "range"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 }
    },
    {
      "type": "row",
      "title": "Error Analysis",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Error Rate by Service",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum by (compose_service) (count_over_time({compose_service=~\"$service\"} | json | level=~\"error|fatal|warn|ERROR|FATAL|WARN|warning|WARNING\" [$__interval]))",
        "legendFormat": "{{compose_service}}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "pointSize": 5, "showPoints": "auto", "spanNulls": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 10 }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "Indexer Errors by Pipeline Step",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum by (step) (count_over_time({compose_service=\"indexer\"} | json | level=~\"error|fatal|ERROR|FATAL\" | step != \"\" [$__interval]))",
        "legendFormat": "{{step}}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "pointSize": 5, "showPoints": "never", "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    },
    {
      "type": "row",
      "title": "Block Progress",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Block Height Over Time",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "max(max_over_time({compose_service=\"indexer\"} | json | unwrap blockNumber [$__interval]))",
        "legendFormat": "Block Height"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "showPoints": "auto", "spanNulls": 600000 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "noValue": "No block data"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 }
    },
    {
      "type": "timeseries",
      "title": "Log Entries/sec (Indexer)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(rate({compose_service=\"indexer\"} | json | blockNumber > 0 [$__interval]))",
        "legendFormat": "entries/sec"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "pointSize": 5, "showPoints": "auto" },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 }
    },
    {
      "type": "row",
      "title": "Pipeline Performance",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Batch Processing Time",
      "description": "Total wall-clock duration per batch (BATCH_SUMMARY step). Spikes indicate slow blocks or RPC latency.",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "max(max_over_time({compose_service=\"indexer\"} | json | step=\"BATCH_SUMMARY\" | unwrap totalDurationMs [$__interval]))",
        "legendFormat": "Total Batch Duration"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "showPoints": "auto", "spanNulls": false },
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2000 },
            { "color": "red", "value": 5000 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }
    },
    {
      "type": "timeseries",
      "title": "Pipeline Step Latency",
      "description": "Max durationMs per pipeline step over time. Identifies which step is the bottleneck.",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "max by (step) (max_over_time({compose_service=\"indexer\"} | json | step != \"\" | step != \"BATCH_SUMMARY\" | durationMs > 0 | unwrap durationMs [$__interval]))",
        "legendFormat": "{{step}}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "pointSize": 5, "showPoints": "auto", "spanNulls": false },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 }
    },
    {
      "type": "stat",
      "title": "Avg Batch Duration",
      "description": "Average total batch processing time over the selected window.",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "avg(avg_over_time({compose_service=\"indexer\"} | json | step=\"BATCH_SUMMARY\" | unwrap totalDurationMs [$__interval]))",
        "queryType": "range"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1000 },
            { "color": "red", "value": 3000 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 32 }
    },
    {
      "type": "stat",
      "title": "Entities per Batch",
      "description": "Average total entities created/updated per batch (BATCH_SUMMARY.totalEntities).",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "avg(avg_over_time({compose_service=\"indexer\"} | json | step=\"BATCH_SUMMARY\" | unwrap totalEntities [$__interval]))",
        "queryType": "range"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 32 }
    },
    {
      "type": "stat",
      "title": "Enrichments per Batch",
      "description": "Average FK enrichment requests per batch (BATCH_SUMMARY.totalEnrichments).",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "avg(avg_over_time({compose_service=\"indexer\"} | json | step=\"BATCH_SUMMARY\" | unwrap totalEnrichments [$__interval]))",
        "queryType": "range"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 32 }
    },
    {
      "type": "stat",
      "title": "Blocks per Batch",
      "description": "Average number of blocks processed per batch.",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "avg(avg_over_time({compose_service=\"indexer\"} | json | step=\"BATCH_SUMMARY\" | unwrap blockCount [$__interval]))",
        "queryType": "range"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 32 }
    },
    {
      "type": "row",
      "title": "Entity & Verification",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Entity Throughput (Raw Events)",
      "description": "Entities persisted per interval by type during PERSIST_RAW step.",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum by (entityType) (sum_over_time({compose_service=\"indexer\"} | json | step=\"PERSIST_RAW\" | count > 0 | unwrap count [$__interval]))",
        "legendFormat": "{{entityType}}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" }, "pointSize": 5, "showPoints": "never" },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 }
    },
    {
      "type": "timeseries",
      "title": "Verification Health (Valid vs Invalid)",
      "description": "Valid and invalid address verifications per interval from the VERIFY step.",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(sum_over_time({compose_service=\"indexer\"} | json | step=\"VERIFY\" | validCount > 0 | unwrap validCount [$__interval]))",
          "legendFormat": "Valid"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(sum_over_time({compose_service=\"indexer\"} | json | step=\"VERIFY\" | newCount > 0 | unwrap newCount [$__interval]))",
          "legendFormat": "New"
        },
        {
          "refId": "C",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(sum_over_time({compose_service=\"indexer\"} | json | step=\"VERIFY\" | invalidCount > 0 | unwrap invalidCount [$__interval]))",
          "legendFormat": "Invalid"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "pointSize": 5, "showPoints": "auto", "spanNulls": false },
          "unit": "none"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Valid" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "New" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "Invalid" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 }
    },
    {
      "type": "row",
      "title": "Metadata Fetch",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Metadata Fetch Backlog",
      "description": "Unfetched entity backlog depth by entity type (LSP3Profile, LSP4Metadata, LSP29EncryptedAsset). A non-zero value at head means there are pending metadata fetches.",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "max by (entityKey) (max_over_time({compose_service=\"indexer\"} | json | entityKey != \"\" | unfetchedCount > 0 | unwrap unfetchedCount [$__interval]))",
        "legendFormat": "{{entityKey}}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "showPoints": "auto", "spanNulls": false },
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 200 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 }
    },
    {
      "type": "timeseries",
      "title": "Metadata Fetch Duration",
      "description": "Total fetch drain duration per entity type at chain head.",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "max by (entityKey) (max_over_time({compose_service=\"indexer\"} | json | entityKey != \"\" | totalProcessed >= 0 | durationMs > 0 | unwrap durationMs [$__interval]))",
        "legendFormat": "{{entityKey}}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "pointSize": 5, "showPoints": "auto", "spanNulls": false },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 }
    },
    {
      "type": "stat",
      "title": "LSP3 Fetch Success Rate",
      "description": "Ratio of successfully processed vs total attempted for LSP3Profile.",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki" },
