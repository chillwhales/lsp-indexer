{
  "name": "@lsp-indexer/lsp1",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lukso/lsp0-contracts": "^0.15.5",
    "@lukso/lsp7-contracts": "^0.16.8",
    "@lukso/lsp8-contracts": "^0.16.7",
    "@lukso/lsp9-contracts": "^0.15.5",
    "@lukso/lsp14-contracts": "^0.15.5",
    "@lukso/lsp26-contracts": "^0.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
