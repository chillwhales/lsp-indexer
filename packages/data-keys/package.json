{
  "name": "@lsp-indexer/data-keys",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6",
    "@lukso/lsp1-contracts": "^0.15.5",
    "@lukso/lsp10-contracts": "^0.15.4",
    "@lukso/lsp12-contracts": "^0.15.4",
    "@lukso/lsp17contractextension-contracts": "^0.16.7",
    "@lukso/lsp3-contracts": "0.16.6",
    "@lukso/lsp4-contracts": "0.16.7",
    "@lukso/lsp5-contracts": "^0.15.4",
    "@lukso/lsp6-contracts": "0.15.5",
    "@lukso/lsp8-contracts": "0.16.7",
    "@lukso/lsp9-contracts": "^0.15.5"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
