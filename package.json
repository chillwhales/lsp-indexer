{
  "name": "@chillwhales/lsp-indexer",
  "description": "",
  "keywords": [],
  "author": "b00ste",
  "license": "MIT",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "hasura:generate": "pnpm --filter=@chillwhales/typeorm hasura:generate",
    "hasura:apply": "pnpm --filter=@chillwhales/typeorm hasura:apply",
    "migration:generate": "pnpm --filter=@chillwhales/typeorm migration:generate",
    "migration:apply": "pnpm --filter=@chillwhales/typeorm migration:apply",
    "start": "pnpm --filter=@chillwhales/indexer start",
    "compare": "pnpm --filter=@chillwhales/comparison-tool compare",
    "codegen": "pnpm --filter @lsp-indexer/node codegen",
    "dev:test": "pnpm --filter test dev",
    "build:react": "pnpm --filter @lsp-indexer/react build",
    "build:all": "pnpm build",
    "validate:publint": "pnpm --filter '@lsp-indexer/*' exec publint",
    "validate:attw": "pnpm --filter '@lsp-indexer/*' exec attw --pack --ignore-rules cjs-resolves-to-esm",
    "validate:publish": "pnpm validate:publint && pnpm validate:attw",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm --filter '@lsp-indexer/*' exec tsc --noEmit",
    "changeset": "changeset",
    "ci:publish": "changeset publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "publint": "^0.3.18",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "ts-node": "^10.9.2"
  }
}
