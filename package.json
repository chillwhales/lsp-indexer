{
  "name": "@chillwhales/lsp-indexer",
  "description": "",
  "keywords": [],
  "author": "b00ste",
  "license": "MIT",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "hasura:generate": "pnpm --filter=@chillwhales/typeorm hasura:generate",
    "hasura:apply": "pnpm --filter=@chillwhales/typeorm hasura:apply",
    "migration:generate": ". ./env.sh && pnpm --filter=@chillwhales/typeorm migration:generate",
    "migration:apply": ". ./env.sh && pnpm --filter=@chillwhales/typeorm migration:apply",
    "start": ". ./env.sh && pnpm --filter=@chillwhales/indexer start",
    "start:v2": ". ./env.sh && pnpm --filter=@chillwhales/indexer-v2 start",
    "compare": "pnpm --filter=@chillwhales/comparison-tool compare",
    "codegen": "pnpm --filter @lsp-indexer/react codegen",
    "dev:test": "pnpm --filter test dev",
    "build:react": "pnpm --filter @lsp-indexer/react build",
    "build:all": "pnpm --filter @lsp-indexer/react build && pnpm --filter test build",
    "validate:publint": "pnpm --filter @lsp-indexer/types exec publint && pnpm --filter @lsp-indexer/node exec publint && pnpm --filter @lsp-indexer/react exec publint && pnpm --filter @lsp-indexer/next exec publint",
    "validate:attw": "pnpm --filter @lsp-indexer/types exec attw --pack && pnpm --filter @lsp-indexer/node exec attw --pack && pnpm --filter @lsp-indexer/react exec attw --pack && pnpm --filter @lsp-indexer/next exec attw --pack",
    "validate:publish": "pnpm validate:publint && pnpm validate:attw"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.2.0",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "publint": "^0.3.18",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "ts-node": "^10.9.2"
  }
}
